# Head Over Heels - controle (teclas default do manual)
# Mover=setas, A=Pular/Teleporte(Space), B=Pegar/Largar(Enter),
# X=Atirar Donut(LCtrl), Y=Trocar Head/Heels(RCtrl), L1/R1=Pular+Pegar(M),
# Start/Select=Menu/Sair(ESC). Nos menus: setas navegam, B confirma, Start sai.

up = up
down = down
left = left
right = right
left_analog_up = up
left_analog_down = down
left_analog_left = left
left_analog_right = right

a = space
b = enter
x = leftctrl
y = rightctrl
l1 = m
r1 = m
start = esc
back = esc
